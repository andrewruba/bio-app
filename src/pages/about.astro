---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../config";
---

<BaseLayout title={`About ${site.name}`} description={`${site.name} is a regulated application engineering partner for life-sciences teams, connecting workflow discovery, R and Python product development, assurance, deployment, and continued operation.`}>
  <section class="about-hero section-pad">
    <div class="wrap about-grid">
      <div data-reveal><span class="eyebrow">About {site.name}</span><h1>The accountable application partner for scientific work.</h1></div>
      <div data-reveal><p class="lead">{site.name} helps life-sciences teams replace fragile spreadsheets, SAS chains, scripts, and manual review processes with governed R and Python applications.</p><p>The category is regulated application engineering: one delivery model that connects the workflow, software product, assurance evidence, deployment, and operating lifecycle.</p></div>
    </div>
  </section>

  <section class="story section-pad">
    <div class="wrap story-grid">
      <div class="story-art" data-reveal><div class="ring r1"></div><div class="ring r2"></div><div class="ring r3"></div><span>P</span><small>Workflow · product · evidence · operation</small></div>
      <div class="timeline" data-reveal>
        <article><span>01 / Discover</span><h2>Begin with the work, not a technology preference.</h2><p>Map the people, decisions, data, systems, manual handoffs, failure points, and intended use before features and infrastructure become expensive.</p></article>
        <article><span>02 / Build</span><h2>Engineer the complete product around the analysis.</h2><p>Keep scientific logic modular and independently tested while designing the interface, integrations, security, observability, deployment, and support model around real users.</p></article>
        <article><span>03 / Assure</span><h2>Match evidence and controls to the application’s use.</h2><p>Connect requirements, risks, controls, tests, approvals, and releases so assurance develops with the product instead of being reconstructed afterward.</p></article>
        <article><span>04 / Operate</span><h2>Remain accountable as the application changes.</h2><p>Plan monitoring, dependency updates, incidents, enhancements, change impact, regression, controlled releases, and periodic review as part of the same system.</p></article>
      </div>
    </div>
  </section>

  <section class="principles section-pad">
    <div class="wrap">
      <div class="section-heading" data-reveal><div><span class="eyebrow mint">Working principles</span><h2>The standard behind the work.</h2></div><p>Technical quality is part of the product. So are the process, the user’s trust, and the organization’s ability to operate what gets built.</p></div>
      <div class="principle-grid" data-reveal><article><span>01</span><h3>Workflow before interface</h3><p>Observe the decisions, handoffs, failure points, and responsibilities before choosing features.</p></article><article><span>02</span><h3>Logic outside the UI</h3><p>Keep scientific calculations modular and independently tested so they can be verified, reused, and changed safely.</p></article><article><span>03</span><h3>Assurance from intended use</h3><p>Apply evidence and controls in proportion to how the application is actually used.</p></article><article><span>04</span><h3>AI behind explicit standards</h3><p>Use AI to accelerate precise work while people remain accountable for judgment, risk, and release.</p></article><article><span>05</span><h3>Customer-owned foundations</h3><p>Build for the platforms, teams, and source-control boundaries the organization already governs.</p></article><article><span>06</span><h3>Operation is designed</h3><p>Monitoring, support, changes, evidence, and handover belong in the architecture before go-live.</p></article></div>
    </div>
  </section>

  <section class="capabilities section-pad">
    <div class="wrap capabilities-grid" data-reveal><div><span class="eyebrow">Full-lifecycle capability</span><h2>Science, software, and assurance in one operating model.</h2></div><div class="capability-list"><span>Scientific workflow discovery</span><span>R and Python product engineering</span><span>Shiny, Streamlit, Dash, React & APIs</span><span>Data and model integration</span><span>User-centered workflow design</span><span>Automated verification</span><span>Validation-ready evidence</span><span>Deployment and managed releases</span></div></div>
  </section>

  <CtaBand eyebrow="Start with one bounded workflow" title="Bring the process that needs a durable product owner." />
</BaseLayout>

<style>
  .about-hero { background: var(--paper); }
  .about-grid { display: grid; gap: clamp(3rem,8vw,9rem); grid-template-columns: 1.2fr .8fr; }
  .about-hero h1 { font-size: clamp(4rem,7vw,7.5rem); margin: 1.2rem 0 0; max-width: 12ch; }
  .about-hero .lead { color: var(--ink); font-family: var(--font-serif); font-size: clamp(1.4rem,2vw,1.9rem); line-height: 1.45; }
  .story { background: var(--wash); }
  .story-grid { align-items: start; display: grid; gap: clamp(3rem,8vw,9rem); grid-template-columns: .7fr 1.3fr; }
  .story-art { aspect-ratio: 4/5; background: var(--ink); color: var(--paper); display: grid; overflow: hidden; place-items: center; position: sticky; top: 8rem; }
  .story-art > span { font-family: var(--font-serif); font-size: clamp(5rem,10vw,10rem); position: relative; z-index: 2; }
  .story-art small { bottom: 1.2rem; color: var(--mint); font-size: .55rem; letter-spacing: .08em; position: absolute; text-transform: uppercase; }
  .ring { border: 1px solid rgba(212,255,116,.4); border-radius: 50%; position: absolute; }.r1{height:35%;width:44%}.r2{height:60%;width:75%}.r3{height:90%;width:112%}
  .timeline { border-left: 1px solid var(--line-strong); }
  .timeline article { padding: 1rem 0 5rem clamp(2rem,5vw,5rem); position: relative; }.timeline article::before{background:var(--coral);border-radius:50%;content:"";height:.7rem;left:-.37rem;position:absolute;top:1rem;width:.7rem}
  .timeline article > span { color: var(--teal); font-size: .65rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
  .timeline h2 { font-size: clamp(2rem,4vw,3.8rem); margin: 1rem 0; max-width: 13ch; }.timeline p{max-width:42rem}
  .principles { background: var(--teal); color: var(--paper); }.principles :global(.section-heading h2){color:var(--paper)}.principles :global(.section-heading p){color:var(--white-soft)}
  .principle-grid { display: grid; grid-template-columns: repeat(3,1fr); }.principle-grid article{border:1px solid rgba(255,255,255,.25);min-height:22rem;padding:2rem}.principle-grid span{color:var(--mint);font-size:.65rem;font-weight:800}.principle-grid h3{color:var(--paper);margin:5rem 0 1rem}.principle-grid p{color:var(--white-soft);font-size:.82rem}
  .capabilities { background: var(--paper-deep); }.capabilities-grid{display:grid;gap:clamp(3rem,8vw,9rem);grid-template-columns:.8fr 1.2fr}.capabilities h2{margin:1rem 0 0}.capability-list{display:grid;grid-template-columns:1fr 1fr}.capability-list span{border-top:1px solid var(--line-strong);color:var(--ink);font-family:var(--font-serif);font-size:1.1rem;padding:1rem}.capability-list span:nth-child(even){border-left:1px solid var(--line)}
  @media(max-width:850px){.about-grid,.story-grid,.capabilities-grid{grid-template-columns:1fr}.story-art{max-width:32rem;position:relative;top:auto}.principle-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:600px){.principle-grid,.capability-list{grid-template-columns:1fr}.capability-list span:nth-child(even){border-left:0}}
</style>

<style>
  .about-hero { background: var(--paper); padding-bottom: clamp(6rem,11vw,10rem); padding-top: clamp(6rem,10vw,9rem); }
  .about-grid { align-items: end; grid-template-columns: 1.25fr .75fr; }
  .about-hero h1 { font-size: clamp(3.9rem,7vw,7.25rem); line-height: .95; margin-top: 1.5rem; }
  .about-hero .lead { font-size: clamp(1.25rem,1.8vw,1.6rem); font-weight: 500; }

  .story { background: var(--paper-deep); }
  .story-art { aspect-ratio: 1; border-radius: var(--radius); top: 7rem; }
  .timeline { border: 0; display: grid; gap: 1rem; }
  .timeline article { background: var(--paper); border-radius: var(--radius); padding: clamp(1.75rem,4vw,3.5rem); }
  .timeline article::before { display: none; }
  .timeline article > span { font-family: var(--font-mono); font-weight: 500; }
  .timeline h2 { margin-top: 2.5rem; }

  .principles { background: #133c2d; }
  .principle-grid { gap: .8rem; }
  .principle-grid article { background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12); border-radius: 1rem; min-height: 21rem; }
  .principle-grid h3 { margin-top: 4.5rem; }

  .capabilities { background: var(--paper); }
  .capability-list { gap: .8rem; }
  .capability-list span { background: var(--paper-deep); border: 0; border-radius: .8rem; font-size: 1rem; font-weight: 600; padding: 1.35rem; }
  .capability-list span:nth-child(even) { border-left: 0; }

  @media(max-width:850px) {
    .about-grid,
    .story-grid,
    .capabilities-grid { grid-template-columns: 1fr; }
    .story-art { max-width: 34rem; position: relative; top: auto; }
    .principle-grid { grid-template-columns: 1fr 1fr; }
  }
  @media(max-width:600px) {
    .about-hero h1 { font-size: clamp(3.15rem,14vw,4.5rem); }
    .principle-grid,
    .capability-list { grid-template-columns: 1fr; }
  }
</style>

<style>
  .story-art small { font-size: .64rem; }
  .timeline article > span { font-size: .71rem; }
  .principle-grid article { min-height: 18rem; }
  .principle-grid h3 { margin-top: 3.25rem; }
  .principle-grid p { font-size: .92rem; }
  .principle-grid span { font-size: .72rem; }

  @media(max-width:600px) {
    .principle-grid article { min-height: 16rem; }
  }
</style>
