---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { services } from "../data/services";
import { site } from "../config";
---

<BaseLayout>
  <section class="hero">
    <div class="hero-grid wrap">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Regulated application engineering</span>
        <h1>Turn critical scientific workflows into applications teams can trust.</h1>
        <p class="hero-dek">We replace slow spreadsheets, SAS chains, and manual analysis with governed R and Python applications—built quickly, validated when required, and supported as they change.</p>
        <div class="hero-actions">
          <a class="button" href="/contact">Discuss a workflow <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#lifecycle">See the application lifecycle <span aria-hidden="true">↓</span></a>
        </div>
        <p class="hero-note"><span>✦</span> AI-accelerated delivery. Human-accountable releases.</p>
      </div>
      <div class="hero-visual" data-reveal>
        <div class="visual-topline"><span>Scientific review workspace</span><span class="live-dot">controlled</span></div>
        <div class="app-window">
          <aside class="app-side">
            <span class="app-logo">S·S</span>
            <span>Overview</span><span class="selected">Model review</span><span>Samples</span><span>Evidence</span>
          </aside>
          <div class="app-main">
            <div class="app-heading"><div><small>MODEL / 03</small><strong>Potency assay review</strong></div><span>v1.8.2</span></div>
            <div class="metrics"><div><small>Samples</small><strong>148</strong></div><div><small>Within range</small><strong>92%</strong></div><div><small>Review state</small><strong>Ready</strong></div></div>
            <div class="plot-card">
              <div class="plot-label"><span>Observed vs. predicted</span><span>R² 0.91</span></div>
              <svg viewBox="0 0 520 220" role="img" aria-label="Observed versus predicted assay response chart">
                <g class="grid-lines"><path d="M40 20V185M40 185H500M40 145H500M40 105H500M40 65H500" /></g>
                <path class="band" d="M40 166 C135 145 205 124 285 94 S410 57 500 34 L500 69 C403 80 346 110 283 126 S145 171 40 184Z" />
                <path class="curve" d="M40 175 C138 150 205 131 286 101 S411 64 500 45" />
                <g class="points"><circle cx="73" cy="164" r="5"/><circle cx="111" cy="154" r="5"/><circle cx="151" cy="142" r="5"/><circle cx="192" cy="133" r="5"/><circle cx="230" cy="117" r="5"/><circle cx="269" cy="112" r="5"/><circle cx="305" cy="91" r="5"/><circle cx="348" cy="88" r="5"/><circle cx="390" cy="70" r="5"/><circle cx="426" cy="68" r="5"/><circle cx="466" cy="50" r="5"/></g>
              </svg>
            </div>
            <div class="trace-row"><span><i></i> Requirement 4.2</span><span>Risk R-07</span><span>Test E2E-14 passed</span><span class="trace-check">✓</span></div>
          </div>
        </div>
        <div class="visual-caption"><span>Analysis</span><span>Workflow</span><span>Evidence</span><span>Release</span></div>
      </div>
    </div>
  </section>

  <section class="proof-rail">
    <div class="wrap proof-grid">
      <div><strong>10+ years</strong><span>scientific research & software</span></div>
      <div><strong>R + Python</strong><span>Shiny, Streamlit, Dash & APIs</span></div>
      <div><strong>Scientist-builder</strong><span>PhD, published researcher, inventor</span></div>
      <div><strong>Full lifecycle</strong><span>discovery through managed release</span></div>
    </div>
  </section>

  <section class="problem section-pad">
    <div class="wrap problem-grid" data-reveal>
      <div>
        <span class="eyebrow">The gap we close</span>
        <h2>The analysis works.<br />Everything around it is friction.</h2>
      </div>
      <div class="problem-body">
        <p class="lead">Your scientists already know how to answer the question. They lose time moving files, rerunning scripts, reconciling outputs, rebuilding context, and explaining the process to the next reviewer.</p>
        <div class="friction-list">
          <span><b>01</b> Critical logic lives with one analyst</span>
          <span><b>02</b> Review happens across exports and email</span>
          <span><b>03</b> Every release recreates its evidence</span>
          <span><b>04</b> Useful prototypes stall before production</span>
        </div>
      </div>
    </div>
  </section>

  <section class="lifecycle section-pad" id="lifecycle">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">One accountable lifecycle</span><h2>Start with one workflow. Build toward a platform.</h2></div>
        <p>Each engagement solves the next problem in the application’s life. Enter where the need is real; add infrastructure only after the workflow earns it.</p>
      </div>
      <div class="lifecycle-track" data-reveal>
        {services.map((service, index) => (
          <a href={`/services/${service.slug}`} class="life-card">
            <span class="life-number">{service.number}</span>
            <span class="life-phase">{index < 2 ? "Prove" : index < 4 ? "Build" : index === 4 ? "Operate" : "Scale"}</span>
            <h3>{service.name}</h3>
            <p>{service.description}</p>
            <span class="life-link">Explore <b aria-hidden="true">↗</b></span>
          </a>
        ))}
        <a href="/platform" class="life-card platform-card">
          <span class="life-number">07</span><span class="life-phase">Platform</span>
          <h3>ControlPlane</h3>
          <p>Expose the governed delivery system—templates, controls, evidence, and releases—to customer and partner teams.</p>
          <span class="life-link">See the direction <b aria-hidden="true">↗</b></span>
        </a>
      </div>
    </div>
  </section>

  <section class="workflows section-pad" id="workflows">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">Where applications create leverage</span><h2>Built around the decision, not the framework.</h2></div>
        <p>Shiny, Streamlit, Dash, React, and APIs are tools. The product begins with the scientific decision, the people responsible for it, and the evidence they need.</p>
      </div>
      <div class="workflow-grid">
        <article class="workflow-card featured" data-reveal>
          <div class="workflow-art clinical-art" aria-hidden="true"><span class="dataset d1">ADSL</span><span class="dataset d2">ADAE</span><span class="dataset d3">TFL</span><i></i></div>
          <div class="workflow-copy"><span class="number-label">01 / Clinical & submission support</span><h3>Review and QC without the reconciliation maze.</h3><p>Clinical data review, TFL/ADaM/SDTM QC, submission readiness, biomarker review, cross-study reconciliation, and controlled reporting.</p><div class="tag-row"><span class="tag">Biometrics</span><span class="tag">Statistical programming</span><span class="tag">Data review</span></div></div>
        </article>
        <article class="workflow-card" data-reveal>
          <div class="workflow-art lab-art" aria-hidden="true"><div class="vial v1"></div><div class="vial v2"></div><div class="vial v3"></div><svg viewBox="0 0 300 100"><path d="M0 74 C32 61 47 88 81 65 S130 34 158 58 202 79 229 44 273 22 300 35" /></svg></div>
          <div class="workflow-copy"><span class="number-label">02 / Laboratory & CMC</span><h3>Make methods usable beyond the scientist who wrote them.</h3><p>Assay calculations, sample reconciliation, method transfer, stability review, instrument-data aggregation, and exception workflows above systems of record.</p><div class="tag-row"><span class="tag">Analytical development</span><span class="tag">Digital labs</span></div></div>
        </article>
        <article class="workflow-card" data-reveal>
          <div class="workflow-art model-art" aria-hidden="true"><span>input</span><span>model</span><span>review</span><i></i><i></i></div>
          <div class="workflow-copy"><span class="number-label">03 / Model-enabled research</span><h3>Put advanced models inside a workflow scientists will adopt.</h3><p>Prediction tools, chemometrics, computer vision, simulation orchestration, model review, and human-approved AI capabilities.</p><div class="tag-row"><span class="tag">Discovery</span><span class="tag">ML / AI</span><span class="tag">Modeling</span></div></div>
        </article>
        <article class="workflow-card rescue" data-reveal>
          <div class="workflow-copy"><span class="number-label">04 / Existing app rescue</span><h3>Your useful internal app deserves a production path.</h3><p>Assess architecture and code, separate business logic, add controls and automated regression, reconstruct traceability, deploy, and establish ownership.</p><a class="text-link" href="/services/validated-build">Explore the retrofit path <span aria-hidden="true">↗</span></a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="assurance section-pad" id="assurance">
    <div class="wrap assurance-grid">
      <div class="assurance-intro" data-reveal>
        <span class="eyebrow mint">Assurance follows intended use</span>
        <h2>Enough control for the decision. No compliance theater.</h2>
        <p>Not every application needs the same packet. We classify the use first, then make the engineering and evidence proportionate to risk.</p>
        <a class="text-link light" href="/services/validated-build">See ValidatedBuild <span aria-hidden="true">↗</span></a>
      </div>
      <div class="assurance-levels" data-reveal>
        <article><span>Level 01</span><h3>Exploratory</h3><p>Research, visualization, hypothesis generation, and non-regulated internal analysis.</p><ul><li>Controlled source</li><li>Automated tests</li><li>Deployment record</li><li>User documentation</li></ul></article>
        <article><span>Level 02</span><h3>Controlled</h3><p>Business-critical decision support that does not directly create or approve regulated records.</p><ul><li>Intended use</li><li>Risk assessment</li><li>Traceability</li><li>Access & change controls</li></ul></article>
        <article class="validated-level"><span>Level 03</span><h3>Validated</h3><p>GxP or submission-supporting use requiring formal application assurance.</p><ul><li>Validation plan</li><li>Requirements & risk</li><li>Qualification evidence</li><li>Summary & ongoing plan</li></ul></article>
      </div>
    </div>
  </section>

  <section class="method section-pad" id="method">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">How the work moves</span><h2>Fast feedback. Explicit standards. Evidence as a byproduct.</h2></div>
        <p>AI compresses requirements drafting, scaffolding, test generation, traceability, and change analysis. People remain accountable for scope, scientific correctness, risk, review, and release.</p>
      </div>
      <ol class="method-track" data-reveal>
        <li><span>01</span><strong>Discover</strong><small>workflow · users · value</small></li>
        <li><span>02</span><strong>Specify</strong><small>use · risk · acceptance</small></li>
        <li><span>03</span><strong>Build</strong><small>logic · product · integration</small></li>
        <li><span>04</span><strong>Verify</strong><small>tests · evidence · review</small></li>
        <li><span>05</span><strong>Release</strong><small>approve · deploy · train</small></li>
        <li><span>06</span><strong>Operate</strong><small>observe · change · assure</small></li>
      </ol>
      <div class="method-principles" data-reveal><div><span>01</span><h3>Written before coded</h3><p>Standards, boundaries, and acceptance examples give both engineers and AI precise context.</p></div><div><span>02</span><h3>Shown before revealed</h3><p>Scientists and reviewers see working increments throughout delivery—not one polished surprise at the end.</p></div><div><span>03</span><h3>Owned after launch</h3><p>Deployment, monitoring, support, change, and evidence are designed with the first release.</p></div></div>
    </div>
  </section>

  <section class="founder section-pad" id="founder">
    <div class="wrap founder-grid">
      <div class="founder-portrait" data-reveal aria-label="Abstract founder profile graphic">
        <div class="portrait-grid"></div><span class="portrait-initials">AR</span><span class="portrait-label">Scientist · engineer · operator</span>
      </div>
      <div class="founder-copy" data-reveal>
        <span class="eyebrow">Founder-led by design</span>
        <h2>Built by someone who has lived inside the workflow.</h2>
        <p class="lead">Andrew Ruba is a PhD scientist and senior scientific software engineer who has moved from microscope hardware and computer vision research to production R and Python applications in pharmaceutical R&D.</p>
        <p>His experience includes leading scientific app delivery, integrating advanced models with working products, gathering requirements directly with researchers, and operating a brick-and-mortar business. The through-line is practical: understand how people work, build what changes the work, and stay accountable to the outcome.</p>
        <div class="founder-proof"><span><b>Peer-reviewed</b> scientific research</span><span><b>Patented</b> microscopy invention</span><span><b>Production</b> pharma applications</span><span><b>Founder</b> and business operator</span></div>
        <p class="experience-note">Representative experience belongs to the founder and predates {site.name}; it is not presented as client work of the company.</p>
        <a class="button button-outline" href="/about">Meet the founder <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <section class="fit section-pad-small">
    <div class="wrap fit-grid" data-reveal>
      <div><span class="eyebrow">The best first engagement</span><h2>Material pain. Bounded surface.</h2></div>
      <div><h3>Good place to start</h3><ul><li>A recurring workflow with a committed process owner</li><li>A visible study, submission, or laboratory milestone</li><li>A review or decision layer above existing systems of record</li><li>A result whose cycle time, error, or effort can be measured</li></ul></div>
      <div><h3>Probably not the first move</h3><ul><li>A complete replacement for LIMS, MES, EDC, or QMS</li><li>Autonomous AI making critical regulated decisions</li><li>An enterprise-wide SAS migration with no workflow wedge</li><li>A project with many integrations and no accountable owner</li></ul></div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .hero { background: linear-gradient(135deg, var(--paper) 0 58%, var(--wash) 58%); overflow: hidden; padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 8vw, 7rem); }
  .hero-grid { align-items: center; display: grid; gap: clamp(3rem, 6vw, 7rem); grid-template-columns: 1.02fr 0.98fr; }
  .hero h1 { margin: 1.35rem 0 2rem; max-width: 11ch; }
  .hero-dek { font-size: clamp(1.05rem, 1.5vw, 1.3rem); max-width: 42rem; }
  .hero-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 2rem; margin-top: 2.4rem; }
  .hero-note { align-items: center; display: flex; font-size: 0.72rem; font-weight: 700; gap: 0.5rem; margin: 3rem 0 0; }
  .hero-note span { color: var(--coral); }

  .hero-visual { background: var(--ink); box-shadow: var(--shadow-lg); color: var(--paper); padding: 0.85rem; position: relative; transform: rotate(1.3deg); }
  .hero-visual::before { border: 1px solid var(--coral); content: ""; height: 96%; left: -1.5rem; position: absolute; top: 3rem; width: 100%; z-index: -1; }
  .visual-topline, .visual-caption { align-items: center; display: flex; font-size: 0.62rem; justify-content: space-between; letter-spacing: 0.08em; padding: 0.15rem 0.25rem 0.75rem; text-transform: uppercase; }
  .live-dot { align-items: center; display: flex; gap: 0.4rem; }
  .live-dot::before { background: var(--mint); border-radius: 50%; content: ""; height: 0.45rem; width: 0.45rem; }
  .visual-caption { color: var(--white-soft); padding: 0.75rem 0.25rem 0.1rem; }
  .app-window { background: #f7f8f3; color: var(--ink); display: grid; grid-template-columns: 5.6rem 1fr; min-height: 32rem; }
  .app-side { background: #e8eee7; border-right: 1px solid var(--line); display: flex; flex-direction: column; font-size: 0.55rem; gap: 0.5rem; padding: 1rem 0.55rem; }
  .app-logo { font-family: var(--font-serif); font-size: 1.15rem; margin-bottom: 2.5rem; }
  .app-side span:not(.app-logo) { border-radius: 2px; padding: 0.55rem 0.4rem; }
  .app-side .selected { background: var(--ink); color: var(--paper); }
  .app-main { padding: 1.2rem; }
  .app-heading { align-items: center; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding-bottom: 1rem; }
  .app-heading small, .app-heading strong { display: block; }
  .app-heading small { color: var(--teal); font-size: 0.48rem; letter-spacing: 0.1em; }
  .app-heading strong { font-family: var(--font-serif); font-size: 1.3rem; margin-top: 0.2rem; }
  .app-heading > span { border: 1px solid var(--line); border-radius: 999px; font-size: 0.55rem; padding: 0.35rem 0.55rem; }
  .metrics { display: grid; gap: 0.5rem; grid-template-columns: repeat(3, 1fr); margin: 1rem 0; }
  .metrics div { border: 1px solid var(--line); padding: 0.7rem; }
  .metrics small, .metrics strong { display: block; }
  .metrics small { color: var(--ink-soft); font-size: 0.48rem; }
  .metrics strong { font-family: var(--font-serif); font-size: 1.35rem; margin-top: 0.3rem; }
  .plot-card { border: 1px solid var(--line); padding: 0.75rem; }
  .plot-label { display: flex; font-size: 0.52rem; font-weight: 700; justify-content: space-between; }
  .plot-card svg { margin-top: 0.5rem; }
  .grid-lines { fill: none; opacity: 0.2; stroke: var(--ink); stroke-width: 1; }
  .band { fill: #b9ded7; opacity: 0.7; }
  .curve { fill: none; stroke: var(--teal); stroke-width: 3; }
  .points { fill: var(--coral); stroke: #fff; stroke-width: 2; }
  .trace-row { align-items: center; background: var(--wash); display: grid; font-size: 0.47rem; grid-template-columns: 1.4fr 0.8fr 1.2fr auto; margin-top: 0.6rem; padding: 0.7rem; }
  .trace-row i { background: var(--teal-bright); border-radius: 50%; display: inline-block; height: 0.4rem; margin-right: 0.2rem; width: 0.4rem; }
  .trace-check { background: var(--mint); border-radius: 50%; display: grid; height: 1.4rem; place-items: center; width: 1.4rem; }

  .proof-rail { background: var(--paper-deep); border-bottom: 1px solid var(--line); border-top: 1px solid var(--line); }
  .proof-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .proof-grid div { border-right: 1px solid var(--line); min-height: 7.5rem; padding: 1.7rem 1.5rem; }
  .proof-grid div:first-child { border-left: 1px solid var(--line); }
  .proof-grid strong, .proof-grid span { display: block; }
  .proof-grid strong { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 500; }
  .proof-grid span { color: var(--ink-soft); font-size: 0.68rem; margin-top: 0.4rem; }

  .problem { background: var(--paper); }
  .problem-grid { display: grid; gap: clamp(3rem, 8vw, 9rem); grid-template-columns: 1.05fr 0.95fr; }
  .problem h2 { font-size: clamp(3rem, 5.5vw, 6rem); margin: 1.2rem 0 0; }
  .problem-body .lead { color: var(--ink); font-family: var(--font-serif); font-size: clamp(1.4rem, 2vw, 2rem); line-height: 1.35; }
  .friction-list { border-top: 1px solid var(--line-strong); display: grid; margin-top: 3rem; }
  .friction-list span { border-bottom: 1px solid var(--line); color: var(--ink-soft); font-size: 0.8rem; padding: 1rem 0; }
  .friction-list b { color: var(--coral); display: inline-block; font-size: 0.65rem; margin-right: 1rem; }

  .lifecycle { background: var(--wash-blue); border-top: 1px solid var(--line); }
  .lifecycle-track { display: grid; grid-template-columns: repeat(7, minmax(15rem, 1fr)); overflow-x: auto; padding-bottom: 1rem; scroll-snap-type: x mandatory; }
  .life-card { background: rgba(245,241,232,0.45); border: 1px solid var(--line); color: var(--ink); display: flex; flex-direction: column; min-height: 26rem; padding: 1.3rem; scroll-snap-align: start; text-decoration: none; transition: background 180ms ease, transform 180ms ease; }
  .life-card + .life-card { border-left: 0; }
  .life-card:hover { background: var(--paper); transform: translateY(-0.5rem); }
  .life-number { color: var(--teal); font-size: 0.7rem; font-weight: 800; }
  .life-phase { border-bottom: 1px solid var(--line); color: var(--ink-soft); font-size: 0.6rem; letter-spacing: 0.1em; margin-top: 0.8rem; padding-bottom: 1.3rem; text-transform: uppercase; }
  .life-card h3 { font-size: 1.6rem; margin: 3.2rem 0 1rem; word-break: break-word; }
  .life-card p { font-size: 0.78rem; line-height: 1.5; }
  .life-link { color: var(--teal); display: flex; font-size: 0.7rem; font-weight: 750; justify-content: space-between; margin-top: auto; }
  .platform-card { background: var(--ink); color: var(--paper); }
  .platform-card p, .platform-card .life-phase { color: var(--white-soft); }
  .platform-card .life-number, .platform-card .life-link { color: var(--mint); }

  .workflows { background: var(--paper); }
  .workflow-grid { display: grid; gap: 1rem; grid-template-columns: 1.25fr 0.75fr; }
  .workflow-card { background: #fffdf8; border: 1px solid var(--line); display: grid; grid-template-rows: 15rem 1fr; }
  .workflow-card.featured { grid-row: span 2; grid-template-rows: 25rem 1fr; }
  .workflow-card.rescue { background: var(--coral); display: block; grid-column: 1 / -1; }
  .workflow-copy { padding: clamp(1.5rem, 3vw, 2.8rem); }
  .workflow-copy h3 { margin: 1.1rem 0; max-width: 16ch; }
  .workflow-copy p { font-size: 0.9rem; }
  .workflow-art { background: var(--wash); border-bottom: 1px solid var(--line); overflow: hidden; position: relative; }
  .clinical-art { background: linear-gradient(145deg, #143a3b, #1b716c); }
  .dataset { background: var(--paper); border: 1px solid var(--mint); color: var(--ink); font-family: var(--font-serif); padding: 1.3rem 2rem; position: absolute; }
  .d1 { left: 12%; top: 18%; transform: rotate(-7deg); }.d2 { left: 39%; top: 37%; transform: rotate(4deg); }.d3 { left: 66%; top: 19%; transform: rotate(9deg); }
  .clinical-art i { border: 1px solid var(--mint); border-radius: 50%; height: 19rem; left: 35%; position: absolute; top: -2rem; width: 19rem; }
  .lab-art { background: var(--paper-deep); }
  .vial { border: 2px solid var(--teal); border-radius: 0 0 40% 40%; bottom: 35%; height: 5.5rem; position: absolute; width: 2.8rem; }
  .vial::before { background: var(--ink); content: ""; height: 0.65rem; left: -0.25rem; position: absolute; top: -0.5rem; width: 3.3rem; }
  .v1 { left: 20%; }.v2 { left: 44%; height: 7rem; }.v3 { left: 68%; height: 4.5rem; }
  .lab-art svg { bottom: 0; position: absolute; width: 100%; }
  .lab-art path { fill: none; stroke: var(--coral); stroke-width: 3; }
  .model-art { align-items: center; background: var(--ink); display: flex; gap: 1.8rem; justify-content: center; }
  .model-art span { background: var(--paper); border-radius: 50%; display: grid; font-size: 0.62rem; height: 3.8rem; place-items: center; width: 3.8rem; }
  .model-art i { background: var(--mint); height: 1px; position: absolute; width: 2rem; }
  .model-art i:first-of-type { left: 31%; }.model-art i:last-of-type { left: 60%; }

  .assurance { background: var(--ink); color: var(--paper); }
  .assurance-grid { display: grid; gap: clamp(3rem, 8vw, 8rem); grid-template-columns: 0.72fr 1.28fr; }
  .assurance-intro { align-self: center; }
  .assurance-intro h2 { color: var(--paper); font-size: clamp(3rem, 5vw, 5rem); margin: 1.2rem 0 2rem; }
  .assurance-intro p { color: var(--white-soft); }
  .assurance-levels { border: 1px solid rgba(255,255,255,0.2); display: grid; grid-template-columns: repeat(3, 1fr); }
  .assurance-levels article { display: flex; flex-direction: column; min-height: 34rem; padding: clamp(1.2rem, 2.5vw, 2.2rem); }
  .assurance-levels article + article { border-left: 1px solid rgba(255,255,255,0.2); }
  .assurance-levels article > span { color: var(--mint); font-size: 0.65rem; font-weight: 800; }
  .assurance-levels h3 { color: var(--paper); margin: 5rem 0 1rem; }
  .assurance-levels p { color: var(--white-soft); font-size: 0.8rem; }
