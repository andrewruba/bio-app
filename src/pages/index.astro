---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import EvidenceWorkspace from "../components/EvidenceWorkspace.astro";
import { services } from "../data/services";
import { site } from "../config";
---

<BaseLayout>
  <section class="hero">
    <svg class="hero-contours" viewBox="0 0 1440 650" preserveAspectRatio="none" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="hero-contour-left" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0" stop-color="#bce879" />
          <stop offset="1" stop-color="#64c9ac" />
        </linearGradient>
        <linearGradient id="hero-contour-right" x1="1" y1="1" x2="0" y2="0">
          <stop offset="0" stop-color="#87d5bb" />
          <stop offset="1" stop-color="#bce879" />
        </linearGradient>
      </defs>
      <g class="contour-left">
        <path d="M-95 618C176 615 99 210 348-48" />
        <path d="M-46 634C224 619 143 209 407-48" />
        <path d="M5 648C277 618 191 205 470-48" />
        <path d="M61 660C333 615 244 199 536-48" />
        <path d="M121 670C394 609 302 190 604-48" />
        <path d="M185 677C459 601 365 179 676-48" />
        <path d="M253 682C529 590 433 166 751-48" />
        <path d="M325 684C604 576 506 151 829-48" />
      </g>
      <g class="contour-right">
        <path d="M676-48C1012 154 915 582 1190 684" />
        <path d="M749-48C1080 139 986 574 1260 681" />
        <path d="M821-48C1147 124 1058 563 1326 674" />
        <path d="M890-48C1213 109 1128 550 1387 665" />
        <path d="M957-48C1277 94 1196 535 1445 653" />
        <path d="M1021-48C1340 80 1262 518 1499 639" />
        <path d="M1083-48C1401 66 1326 500 1550 623" />
        <path d="M1143-48C1460 53 1388 480 1598 605" />
      </g>
    </svg>
    <div class="hero-grid wrap">
      <div class="hero-copy" data-reveal>
        <span class="eyebrow">Regulated application engineering</span>
        <h1>Turn critical scientific workflows into applications teams can trust.</h1>
        <p class="hero-dek">We turn spreadsheets, SAS scripts, and manual analyses into production R and Python applications—designed around the people doing the work, validated when required, and supported after release.</p>
        <div class="hero-actions">
          <a class="button" href="/contact">Discuss a workflow <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#lifecycle">See the application lifecycle <span aria-hidden="true">↓</span></a>
        </div>
        <p class="hero-note"><span>✦</span> AI-accelerated delivery. Human-accountable releases.</p>
      </div>
      <div class="hero-visual" data-reveal>
        <div class="visual-topline"><span>Representative assay reporting app</span><span class="live-dot">controlled</span></div>
        <div class="app-window">
          <aside class="app-side">
            <span class="app-logo">{site.name.charAt(0)}</span>
            <span>Overview</span><span>Load data</span><span>Process</span><span class="selected">Generate report</span>
          </aside>
          <div class="app-main">
            <div class="app-heading"><div><small>REPORT / 03</small><strong>Assay analysis report</strong></div><span>v1.8.2</span></div>
            <div class="app-steps" aria-label="Load, process, and generate report workflow">
              <div><small>01</small><span><b>Load</b><em>assay_data.csv</em></span><i>✓</i></div>
              <div><small>02</small><span><b>Process</b><em>validated calculation</em></span><i>✓</i></div>
              <div class="current"><small>03</small><span><b>Generate report</b><em>review-ready output</em></span><i>PDF</i></div>
            </div>
            <div class="metrics"><div><small>Input rows</small><strong>148</strong></div><div><small>Checks passed</small><strong>12/12</strong></div><div><small>Report state</small><strong>Ready</strong></div></div>
            <div class="plot-card">
              <div class="plot-label"><span>4PL dose–response fit</span><span>R² 0.997</span></div>
              <svg viewBox="0 0 520 180" role="img" aria-label="Four-parameter logistic dose-response curve with observed assay sample points">
                <g class="grid-lines"><path d="M40 18V160M40 160H500M40 122H500M40 84H500M40 46H500" /></g>
                <path class="band" d="M40 151 C108 151 154 147 190 132 C221 119 237 92 260 73 C294 47 340 32 500 29 L500 49 C341 52 300 66 267 91 C242 110 226 137 194 151 C157 167 110 171 40 172Z" />
                <path class="curve" d="M40 162 C109 162 155 157 192 142 C224 129 240 101 263 82 C296 56 340 42 500 39" />
                <g class="points"><circle cx="68" cy="160" r="5"/><circle cx="103" cy="159" r="5"/><circle cx="139" cy="154" r="5"/><circle cx="177" cy="145" r="5"/><circle cx="211" cy="130" r="5"/><circle cx="243" cy="105" r="5"/><circle cx="274" cy="74" r="5"/><circle cx="309" cy="59" r="5"/><circle cx="349" cy="47" r="5"/><circle cx="398" cy="43" r="5"/><circle cx="456" cy="38" r="5"/></g>
                <text class="axis-label x-label" x="270" y="176">Log concentration</text>
                <text class="axis-label y-label" x="10" y="92" transform="rotate(-90 10 92)">Response</text>
              </svg>
            </div>
            <div class="trace-row"><span><i></i> Source batch recorded</span><span>Process v1.8.2</span><span>Report QC passed</span><span class="trace-check">✓</span></div>
          </div>
        </div>
        <div class="visual-caption"><span>01 Load</span><span>02 Process</span><span>03 Generate report</span></div>
      </div>
    </div>
  </section>

  <section class="stack-rail" aria-label="Supported application environments">
    <div class="wrap stack-shell">
      <span>Built for the environment you already govern</span>
      <div class="stack-list"><b>R</b><b>Python</b><b>Shiny</b><b>Streamlit</b><b>Posit</b><b>Domino</b><b>Databricks</b><b>Kubernetes</b></div>
    </div>
  </section>

  <section class="problem section-pad">
    <div class="wrap problem-grid" data-reveal>
      <div>
        <span class="eyebrow">The gap we close</span>
        <h2>The analysis works.<br />Running it should not be this hard.</h2>
      </div>
      <div class="problem-body">
        <p class="lead">Your scientists already know how to answer the question. They lose time locating inputs, editing parameters, rerunning scripts, checking outputs, assembling reports, and explaining what changed to reviewers.</p>
        <div class="friction-list">
          <span><b>01</b> Critical calculations depend on one analyst</span>
          <span><b>02</b> Inputs and outputs move through email and shared drives</span>
          <span><b>03</b> Review comments are separated from the results</span>
          <span><b>04</b> Each release requires the same evidence to be rebuilt</span>
        </div>
      </div>
    </div>
    <div class="wrap problem-scene" data-reveal>
      <img src="/images/scientific-team-review-placeholder.webp" alt="Scientific team reviewing analytical results together in a laboratory workspace" loading="eager" fetchpriority="low" />
      <div class="scene-caption"><span>Scientific review environment</span><strong>The interface belongs where the decision is made.</strong></div>
      <div class="scene-workflow" aria-label="Representative review workflow">
        <span class="mini-label">Representative workflow</span>
        <div><small>01</small><b>Load data</b><em>controlled source files</em></div>
        <div><small>02</small><b>Process analysis</b><em>versioned calculations</em></div>
        <div><small>03</small><b>Generate report</b><em>review-ready output</em></div>
      </div>
    </div>
    <div class="wrap operating-facts" data-reveal>
      <div class="facts-label"><span class="eyebrow mint">What every engagement includes</span><p>A clear path from the current process through release and support.</p></div>
      <article><strong>06</strong><span>visible stages from discovery through operation</span></article>
      <article><strong>03</strong><span>levels of control matched to intended use</span></article>
      <article><strong>01</strong><span>team accountable for the application and its release evidence</span></article>
    </div>
  </section>

  <section class="lifecycle section-pad" id="lifecycle">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">One accountable lifecycle</span><h2>Start with one workflow. Build toward a platform.</h2></div>
        <p>Start where the bottleneck is. Add validation, support, and shared infrastructure as the application becomes more important and the portfolio grows.</p>
      </div>
      <div class="lifecycle-track" data-reveal>
        {services.map((service, index) => (
          <a href={`/services/${service.slug}`} class="life-card">
            <span class="life-number">{service.number}</span>
            <span class="life-phase">{index < 2 ? "Prove" : index < 4 ? "Build" : index === 4 ? "Operate" : "Scale"}</span>
            <h3>{service.name}</h3>
            <p>{service.description}</p>
            <span class="life-link">Explore <b aria-hidden="true">↗</b></span>
          </a>
        ))}
        <a href="/platform" class="life-card platform-card">
          <span class="life-number">07</span><span class="life-phase">Platform</span>
          <h3>ControlPlane</h3>
          <p>Reuse approved templates, controls, tests, and release records across customer and partner development teams.</p>
          <span class="life-link">See the direction <b aria-hidden="true">↗</b></span>
        </a>
      </div>
    </div>
  </section>

  <section class="workflows section-pad" id="workflows">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">Where applications create leverage</span><h2>Built around the decision, not the framework.</h2></div>
        <p>Shiny, Streamlit, Dash, React, and APIs are implementation choices. We start with the analysis, the people responsible for it, and the outputs they need to review.</p>
      </div>
      <div class="workflow-grid">
        <article class="workflow-card featured" data-reveal>
          <div class="workflow-art qc-art" aria-label="Representative clinical QC application comparing source and derived clinical datasets">
            <div class="app-art-head"><span>Clinical reconciliation workspace</span><b>Study ABC-101</b></div>
            <div class="qc-summary"><div><small>Datasets</small><strong>03</strong></div><div><small>Checks</small><strong>42</strong></div><div><small>Needs review</small><strong>02</strong></div></div>
            <div class="qc-table">
              <div class="qc-row qc-header"><span>Dataset</span><span>Source</span><span>Derived</span><span>Status</span></div>
              <div class="qc-row"><strong>ADSL</strong><span>148</span><span>148</span><em>Matched</em></div>
              <div class="qc-row attention"><strong>ADAE</strong><span>326</span><span>324</span><em>2 review</em></div>
              <div class="qc-row"><strong>TFL</strong><span>42</span><span>42</span><em>Ready</em></div>
            </div>
            <div class="qc-footer"><span>Comparison rules v1.4</span><b>Open review queue →</b></div>
          </div>
          <div class="workflow-copy"><span class="number-label">01 / Clinical & submission support</span><h3>Review and QC without the reconciliation maze.</h3><p>Clinical data review, TFL/ADaM/SDTM QC, submission readiness, biomarker review, cross-study reconciliation, and controlled reporting.</p><div class="tag-row"><span class="tag">Biometrics</span><span class="tag">Statistical programming</span><span class="tag">Data review</span></div></div>
        </article>
        <div class="workflow-stack">
          <article class="workflow-card" data-reveal>
            <div class="workflow-art flow-art lab-art" aria-label="Representative laboratory application: load an instrument export, process an assay, and generate a method report">
              <div class="flow-chrome"><span>Assay calculation app</span><b>Controlled</b></div>
              <div class="flow-steps">
                <div class="flow-step"><small>01</small><strong>Load</strong><span>Instrument export</span><em>CSV</em></div>
                <i aria-hidden="true">→</i>
                <div class="flow-step"><small>02</small><strong>Process</strong><span>Calculate assay</span><em>QC passed</em></div>
                <i aria-hidden="true">→</i>
                <div class="flow-step active"><small>03</small><strong>Generate report</strong><span>Method report</span><em>PDF</em></div>
              </div>
              <div class="flow-output"><span>assay_report.pdf</span><b>Ready for review</b></div>
            </div>
            <div class="workflow-copy"><span class="number-label">02 / Laboratory & CMC</span><h3>Make methods usable beyond the scientist who wrote them.</h3><p>Assay calculations, sample reconciliation, method transfer, stability review, instrument-data aggregation, and exception review using data from LIMS, ELN, SDMS, and instrument systems.</p><div class="tag-row"><span class="tag">Analytical development</span><span class="tag">Digital labs</span></div></div>
          </article>
          <article class="workflow-card" data-reveal>
            <div class="workflow-art model-review-art" aria-label="Representative model review application showing a prediction, confidence, coverage, and drift checks">
              <div class="app-art-head"><span>Model review application</span><b>Model v2.3</b></div>
              <div class="prediction-panel"><div><small>Predicted response</small><strong>87.4%</strong><span>Within decision range</span></div><div class="confidence"><small>Confidence</small><div><i></i></div><b>High</b></div></div>
              <div class="model-checks"><div><small>Input coverage</small><strong>100%</strong></div><div><small>Domain check</small><strong>Passed</strong></div><div><small>Drift</small><strong>Low</strong></div></div>
              <div class="model-review-footer"><span>Human review required</span><b>Review prediction →</b></div>
              </div>
            <div class="workflow-copy"><span class="number-label">03 / Model-enabled research</span><h3>Put advanced models inside a workflow scientists will adopt.</h3><p>Prediction tools, chemometrics, computer vision, simulation orchestration, model review, and human-approved AI capabilities.</p><div class="tag-row"><span class="tag">Discovery</span><span class="tag">ML / AI</span><span class="tag">Modeling</span></div></div>
          </article>
        </div>
        <article class="workflow-card rescue" data-reveal>
          <div class="workflow-copy"><span class="number-label">04 / Existing app rescue</span><h3>A useful internal app should not stay stuck on a laptop or shared server.</h3><p>Review the code, separate calculations from the interface, add automated tests and access controls, document requirements and risks, deploy, and establish support ownership.</p><a class="text-link" href="/services/validated-build">Explore the upgrade path <span aria-hidden="true">↗</span></a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="assurance section-pad" id="assurance">
    <div class="wrap assurance-grid">
      <div class="assurance-intro" data-reveal>
        <span class="eyebrow mint">Controls follow intended use</span>
        <h2>Apply the controls the application actually needs.</h2>
        <p>Not every application requires the same validation effort. Define intended use first, then match the engineering, testing, documentation, and approvals to the risk.</p>
        <a class="text-link light" href="/services/validated-build">See ValidatedBuild <span aria-hidden="true">↗</span></a>
      </div>
      <div class="assurance-levels" data-reveal>
        <article><span>Level 01</span><h3>Exploratory</h3><p>Research, visualization, hypothesis generation, and non-regulated internal analysis.</p><ul><li>Controlled source</li><li>Automated tests</li><li>Deployment record</li><li>User documentation</li></ul></article>
        <article><span>Level 02</span><h3>Controlled</h3><p>Business-critical analysis that should be tested, versioned, access-controlled, and released through change control.</p><ul><li>Intended use</li><li>Risk assessment</li><li>Traceability</li><li>Access & change controls</li></ul></article>
        <article class="validated-level"><span>Level 03</span><h3>Validated</h3><p>GxP or submission-supporting use requiring formal validation evidence and quality approval.</p><ul><li>Validation plan</li><li>Requirements & risk</li><li>Qualification evidence</li><li>Summary & ongoing plan</li></ul></article>
      </div>
    </div>
  </section>

  <section class="method section-pad" id="method">
    <div class="wrap">
      <div class="section-heading" data-reveal>
        <div><span class="eyebrow">How the work moves</span><h2>Fast feedback. Clear requirements. Test evidence captured during delivery.</h2></div>
        <p>AI speeds up requirements drafting, application setup, test generation, traceability, and change analysis. People remain accountable for scope, scientific correctness, risk, review, and release.</p>
      </div>
      <ol class="method-track" data-reveal>
        <li><span>01</span><strong>Discover</strong><small>workflow · users · value</small></li>
        <li><span>02</span><strong>Specify</strong><small>use · risk · acceptance</small></li>
        <li><span>03</span><strong>Build</strong><small>calculations · interface · integration</small></li>
        <li><span>04</span><strong>Verify</strong><small>tests · evidence · review</small></li>
        <li><span>05</span><strong>Release</strong><small>approve · deploy · train</small></li>
        <li><span>06</span><strong>Operate</strong><small>observe · change · assure</small></li>
      </ol>
      <div class="method-principles" data-reveal><div><span>01</span><h3>Written before coded</h3><p>Standards, boundaries, and acceptance examples give both engineers and AI precise context.</p></div><div><span>02</span><h3>Shown before revealed</h3><p>Scientists and reviewers see working increments throughout delivery—not one polished surprise at the end.</p></div><div><span>03</span><h3>Owned after launch</h3><p>Deployment, monitoring, support, change, and evidence are designed with the first release.</p></div></div>
    </div>
  </section>

  <section class="partner section-pad" id="approach">
    <div class="wrap partner-grid">
      <div class="partner-product" data-reveal><EvidenceWorkspace compact /></div>
      <div class="partner-copy" data-reveal>
        <span class="eyebrow">One partner across the lifecycle</span>
        <h2>The application is only as strong as the system around it.</h2>
        <p class="lead">{site.name} handles the full application lifecycle: understand the current process, build and test the application, prepare validation evidence, deploy it, and support each release.</p>
        <p>A useful analysis does not become a dependable application by adding an interface alone. User adoption, testing, traceability, release controls, infrastructure, and support ownership must be designed together.</p>
        <div class="partner-proof"><span><b>Discover</b> the current process</span><span><b>Build</b> the production application</span><span><b>Validate</b> based on intended use</span><span><b>Support</b> each controlled change</span></div>
        <a class="button button-outline" href="/about">How {site.name} works <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <section class="fit section-pad-small">
    <div class="wrap fit-grid" data-reveal>
      <div><span class="eyebrow">A good first project</span><h2>Frequent pain. Clear scope.</h2></div>
      <div><h3>Good place to start</h3><ul><li>A recurring manual analysis with an identified process owner</li><li>A visible study, submission, or laboratory milestone</li><li>An application that uses data from existing systems rather than replacing them</li><li>A result whose turnaround time, error rate, or effort can be measured</li></ul></div>
      <div><h3>Probably not the first move</h3><ul><li>A complete replacement for LIMS, MES, EDC, or QMS</li><li>Autonomous AI making critical regulated decisions</li><li>A company-wide SAS migration before a priority analysis is selected</li><li>A project with many integrations and no accountable process owner</li></ul></div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .hero { background: linear-gradient(135deg, var(--paper) 0 58%, var(--wash) 58%); overflow: hidden; padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 8vw, 7rem); }
  .hero-grid { align-items: center; display: grid; gap: clamp(3rem, 6vw, 7rem); grid-template-columns: 1.02fr 0.98fr; }
  .hero h1 { margin: 1.35rem 0 2rem; max-width: 11ch; }
  .hero-dek { font-size: clamp(1.05rem, 1.5vw, 1.3rem); max-width: 42rem; }
  .hero-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 2rem; margin-top: 2.4rem; }
  .hero-note { align-items: center; display: flex; font-size: 0.72rem; font-weight: 700; gap: 0.5rem; margin: 3rem 0 0; }
  .hero-note span { color: var(--accent-strong); }

  .hero-visual { background: var(--ink); box-shadow: var(--shadow-lg); color: var(--paper); padding: 0.85rem; position: relative; transform: rotate(1.3deg); }
  .hero-visual::before { border: 1px solid var(--accent); content: ""; height: 96%; left: -1.5rem; position: absolute; top: 3rem; width: 100%; z-index: -1; }
  .visual-topline, .visual-caption { align-items: center; display: flex; font-size: 0.62rem; justify-content: space-between; letter-spacing: 0.08em; padding: 0.15rem 0.25rem 0.75rem; text-transform: uppercase; }
  .live-dot { align-items: center; display: flex; gap: 0.4rem; }
  .live-dot::before { background: var(--mint); border-radius: 50%; content: ""; height: 0.45rem; width: 0.45rem; }
  .visual-caption { color: var(--white-soft); padding: 0.75rem 0.25rem 0.1rem; }
  .app-window { background: #f7f8f3; color: var(--ink); display: grid; grid-template-columns: 5.6rem 1fr; min-height: 32rem; }
  .app-side { background: #e8eee7; border-right: 1px solid var(--line); display: flex; flex-direction: column; font-size: 0.55rem; gap: 0.5rem; padding: 1rem 0.55rem; }
  .app-logo { font-family: var(--font-serif); font-size: 1.15rem; margin-bottom: 2.5rem; }
  .app-side span:not(.app-logo) { border-radius: 2px; padding: 0.55rem 0.4rem; }
  .app-side .selected { background: var(--ink); color: var(--paper); }
  .app-main { padding: 1.2rem; }
  .app-heading { align-items: center; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding-bottom: 1rem; }
  .app-heading small, .app-heading strong { display: block; }
  .app-heading small { color: var(--teal); font-size: 0.48rem; letter-spacing: 0.1em; }
  .app-heading strong { font-family: var(--font-serif); font-size: 1.3rem; margin-top: 0.2rem; }
  .app-heading > span { border: 1px solid var(--line); border-radius: 999px; font-size: 0.55rem; padding: 0.35rem 0.55rem; }
  .metrics { display: grid; gap: 0.5rem; grid-template-columns: repeat(3, 1fr); margin: 1rem 0; }
  .metrics div { border: 1px solid var(--line); padding: 0.7rem; }
  .metrics small, .metrics strong { display: block; }
  .metrics small { color: var(--ink-soft); font-size: 0.48rem; }
  .metrics strong { font-family: var(--font-serif); font-size: 1.35rem; margin-top: 0.3rem; }
  .plot-card { border: 1px solid var(--line); padding: 0.75rem; }
  .plot-label { display: flex; font-size: 0.52rem; font-weight: 700; justify-content: space-between; }
  .plot-card svg { margin-top: 0.5rem; }
  .grid-lines { fill: none; opacity: 0.2; stroke: var(--ink); stroke-width: 1; }
  .band { fill: #b9ded7; opacity: 0.7; }
  .curve { fill: none; stroke: var(--teal); stroke-width: 3; }
  .points { fill: var(--accent-strong); stroke: #fff; stroke-width: 2; }
  .axis-label { fill: var(--ink-soft); font-family: var(--font-mono); font-size: 7px; letter-spacing: .03em; text-anchor: middle; }
  .trace-row { align-items: center; background: var(--wash); display: grid; font-size: 0.47rem; grid-template-columns: 1.4fr 0.8fr 1.2fr auto; margin-top: 0.6rem; padding: 0.7rem; }
  .trace-row i { background: var(--teal-bright); border-radius: 50%; display: inline-block; height: 0.4rem; margin-right: 0.2rem; width: 0.4rem; }
  .trace-check { background: var(--mint); border-radius: 50%; display: grid; height: 1.4rem; place-items: center; width: 1.4rem; }

  .proof-rail { background: var(--paper-deep); border-bottom: 1px solid var(--line); border-top: 1px solid var(--line); }
  .proof-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .proof-grid div { border-right: 1px solid var(--line); min-height: 7.5rem; padding: 1.7rem 1.5rem; }
  .proof-grid div:first-child { border-left: 1px solid var(--line); }
  .proof-grid strong, .proof-grid span { display: block; }
  .proof-grid strong { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 500; }
  .proof-grid span { color: var(--ink-soft); font-size: 0.68rem; margin-top: 0.4rem; }

  .problem { background: var(--paper); }
  .problem-grid { display: grid; gap: clamp(3rem, 8vw, 9rem); grid-template-columns: 1.05fr 0.95fr; }
