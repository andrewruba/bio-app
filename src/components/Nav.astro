---
import BrandMark from "./BrandMark.astro";
import { services } from "../data/services";
import { site } from "../config";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isServices = currentPath.startsWith("/services/");
---

<header class="site-header" data-header>
  <div class="nav-shell">
    <a class="brand-link" href="/" aria-label={`${site.name} home`}><BrandMark /></a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
      <span>Menu</span>
      <span class="menu-lines" aria-hidden="true"></span>
    </button>
    <nav class="primary-nav" id="primary-nav" aria-label="Primary navigation">
      <details class="services-menu" open={false}>
        <summary class:list={[{ active: isServices }]}>Services <span aria-hidden="true">⌄</span></summary>
        <div class="service-popover">
          <div class="popover-intro">
            <span class="mini-label">The application lifecycle</span>
            <p>Start with one critical workflow. Build the capability only as value and evidence compound.</p>
          </div>
          <ol>
            {services.map((service) => (
              <li>
                <a href={`/services/${service.slug}`} class:list={[{ active: currentPath === `/services/${service.slug}` }]}>
                  <span>{service.number}</span>
                  <span><strong>{service.name}</strong><small>{service.navName}</small></span>
                  <span aria-hidden="true">↗</span>
                </a>
              </li>
            ))}
          </ol>
          <a class="platform-link" href="/platform"><span>07</span><span><strong>ControlPlane</strong><small>The governed delivery system</small></span><span aria-hidden="true">↗</span></a>
        </div>
      </details>
      <a class:list={[{ active: currentPath === "/platform" }]} href="/platform">Platform</a>
      <a class:list={[{ active: currentPath === "/about" }]} href="/about">About</a>
      <a class="button button-small" href="/contact">{site.consultationLabel}<span aria-hidden="true">↗</span></a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
  const nav = document.querySelector<HTMLElement>(".primary-nav");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav?.classList.toggle("is-open", !open);
    document.body.classList.toggle("menu-open", !open);
  });

  const serviceDetails = document.querySelector<HTMLDetailsElement>(".services-menu");
  document.addEventListener("click", (event) => {
    if (serviceDetails?.open && !serviceDetails.contains(event.target as Node)) serviceDetails.open = false;
  });
</script>

<style>
  .site-header {
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
  }

  .nav-shell {
    align-items: center;
    display: flex;
    height: 5.4rem;
    justify-content: space-between;
    margin: auto;
    max-width: var(--wide);
    padding: 0 var(--gutter);
  }

  .brand-link { text-decoration: none; }

  .primary-nav {
    align-items: center;
    display: flex;
    gap: clamp(1.4rem, 2.5vw, 2.6rem);
  }

  .primary-nav > a,
  summary {
    color: var(--ink);
    cursor: pointer;
    font-size: 0.84rem;
    font-weight: 700;
    list-style: none;
    text-decoration: none;
  }

  summary::-webkit-details-marker { display: none; }
  summary span { color: var(--mint-dark); margin-left: 0.25rem; }
  .primary-nav > a:not(.button):hover,
  summary:hover,
  .active { color: var(--teal); }

  .primary-nav > .button { color: var(--paper); }

  .services-menu { position: relative; }

  .service-popover {
    background: var(--paper);
    border: 1px solid var(--line-strong);
    box-shadow: var(--shadow-lg);
    display: grid;
    grid-template-columns: 0.74fr 1.5fr;
    left: 50%;
    min-width: min(54rem, calc(100vw - 3rem));
    opacity: 0;
    padding: 1rem;
    position: absolute;
    top: 2.6rem;
    transform: translate(-42%, -0.5rem);
    transition: opacity 180ms ease, transform 180ms ease;
  }

  details[open] .service-popover { opacity: 1; transform: translate(-42%, 0); }

  .popover-intro {
    background: var(--ink);
    color: var(--paper);
    padding: 1.5rem;
  }

  .popover-intro p { color: var(--white-soft); font-family: var(--font-serif); font-size: 1.35rem; line-height: 1.18; margin: 2rem 0 0; }
  .service-popover ol { display: grid; grid-template-columns: 1fr 1fr; list-style: none; margin: 0; padding: 0 0 0 0.75rem; }
  .service-popover li { border-bottom: 1px solid var(--line); }

  .service-popover li a,
  .platform-link {
    align-items: center;
    color: var(--ink);
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1.4rem 1fr auto;
    min-height: 4.5rem;
    padding: 0.65rem 0.8rem;
    text-decoration: none;
  }

  .service-popover li a:hover { background: var(--wash); }
  .service-popover li a > span:first-child,
  .platform-link > span:first-child { color: var(--teal); font-size: 0.68rem; font-weight: 800; }
  .service-popover strong,
  .service-popover small { display: block; }
  .service-popover strong { font-size: 0.83rem; }
  .service-popover small { color: var(--ink-soft); font-size: 0.68rem; margin-top: 0.14rem; }
  .platform-link { border-left: 0.75rem solid var(--mint); grid-column: 2; margin-left: 0.75rem; }

  .menu-toggle {
    align-items: center;
    background: none;
    border: 1px solid var(--ink);
    color: var(--ink);
    display: flex;
    font: inherit;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.55rem 0.7rem;
  }

  @media (min-width: 801px) {
    .menu-toggle { display: none; }
  }

  @media (max-width: 800px) {
    .nav-shell { height: 4.7rem; }
    .menu-toggle { display: flex; gap: 0.7rem; }
    .primary-nav {
      align-items: stretch;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      display: none;
      flex-direction: column;
      gap: 0;
      left: 0;
      max-height: calc(100svh - 4.7rem);
      overflow-y: auto;
      padding: 1rem var(--gutter) 2rem;
      position: absolute;
      top: 4.7rem;
      width: 100%;
    }
    .primary-nav.is-open { display: flex; }
    .primary-nav > a,
    summary { border-bottom: 1px solid var(--line); font-size: 1rem; padding: 1rem 0; }
    .primary-nav .button { margin-top: 1rem; text-align: center; }
    .service-popover {
      border: 0;
      box-shadow: none;
      display: block;
      min-width: 0;
      opacity: 1;
      padding: 0;
      position: static;
      transform: none !important;
    }
    .popover-intro { display: none; }
    .service-popover ol { display: block; padding: 0; }
    .service-popover li a { padding-left: 0.4rem; }
    .platform-link { border-left-width: 0.25rem; margin-left: 0; }
  }
</style>
