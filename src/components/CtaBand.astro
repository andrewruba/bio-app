---
interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  label?: string;
}

const {
  eyebrow = "Start with the workflow",
  title = "Bring the process that is slowing good science down.",
  text = "In 30 minutes, we can identify the users, decisions, systems, risk, and smallest useful next step. No platform pitch required.",
  label = "Discuss a workflow"
} = Astro.props;
---

<section class="cta-band section-pad">
  <div class="wrap cta-grid" data-reveal>
    <div>
      <span class="eyebrow mint">{eyebrow}</span>
      <h2>{title}</h2>
    </div>
    <div>
      <p>{text}</p>
      <a class="button button-mint" href="/contact">{label}<span aria-hidden="true">↗</span></a>
    </div>
  </div>
</section>

<style>
  .cta-band { background: var(--teal); color: var(--paper); overflow: hidden; position: relative; }
  .cta-band::after { border: 1px solid rgba(212, 255, 116, 0.24); border-radius: 50%; content: ""; height: 35rem; position: absolute; right: -12rem; top: -20rem; width: 35rem; }
  .cta-grid { align-items: end; display: grid; gap: clamp(2rem, 8vw, 8rem); grid-template-columns: 1.35fr 0.75fr; position: relative; z-index: 1; }
  h2 { color: var(--paper); font-size: clamp(2.7rem, 5vw, 5.5rem); margin: 1rem 0 0; max-width: 14ch; }
  p { color: var(--white-soft); margin: 0 0 2rem; }
  @media (max-width: 720px) { .cta-grid { grid-template-columns: 1fr; } }
</style>
