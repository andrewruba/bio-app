---
import { site } from "../config";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<span class:list={["brand", { compact }]} aria-label={site.name}>
  <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true">
    <rect class="brand-stem" x="5" y="4" width="8" height="32" rx="4" />
    <path class="brand-bowl" d="M9 4h12c9.2 0 15 5.1 15 13.5S30.2 31 21 31H9v-7h12c4.6 0 7-2.3 7-6.5S25.6 11 21 11H9V4Z" />
    <path class="brand-proof" d="m17.2 17.5 2.7 2.7 5.3-5.8" />
  </svg>
  <span class="brand-type">{site.name}</span>
</span>

<style>
  .brand {
    --brand-mark: var(--teal);
    --brand-proof: var(--paper);
    align-items: center;
    color: var(--ink);
    display: inline-flex;
    gap: .72rem;
  }

  .brand-mark {
    flex: 0 0 auto;
    height: 2.15rem;
    overflow: visible;
    width: 2.15rem;
  }

  .brand-stem,
  .brand-bowl {
    fill: var(--brand-mark);
  }

  .brand-proof {
    fill: none;
    stroke: var(--brand-proof);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.35;
  }

  .brand-type {
    font-family: var(--font-sans);
    font-size: .98rem;
    font-weight: 680;
    letter-spacing: -.035em;
    line-height: 1;
  }

  .compact .brand-type {
    display: none;
  }
</style>
