---
interface Props {
  name: "arrow-up-right" | "arrow-down" | "arrow-left" | "arrow-right" | "chevron-down";
}

const { name } = Astro.props;
---

<svg class={`ui-icon ui-icon-${name}`} viewBox="0 0 16 16" aria-hidden="true" focusable="false">
  {name === "arrow-up-right" && <path d="M4 12 12 4M6 4h6v6" />}
  {name === "arrow-down" && <path d="M8 3v10M4.5 9.5 8 13l3.5-3.5" />}
  {name === "arrow-left" && <path d="M13 8H3M6.5 4.5 3 8l3.5 3.5" />}
  {name === "arrow-right" && <path d="M3 8h10M9.5 4.5 13 8l-3.5 3.5" />}
  {name === "chevron-down" && <path d="m4 6 4 4 4-4" />}
</svg>

<style>
  .ui-icon {
    display: block;
    flex: 0 0 auto;
    height: 1em;
    overflow: visible;
    width: 1em;
  }

  path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
    vector-effect: non-scaling-stroke;
  }
</style>
